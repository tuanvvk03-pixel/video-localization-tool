# Reference only. This repo does not auto-load `.env`.
# Set these variables in PowerShell before launching the app, or save
# credentials in App Settings where supported.

# OpenAI
# Required for translate backend `block_v2`.
# OPENAI_API_KEY=sk-...

# Optional override for the default translation model.
# If unset, runtime falls back to `gpt-5.4` (Chat Completions).
# OPENAI_TRANSLATION_MODEL=gpt-5.4

# ffmpeg / ffprobe
# If unset, the app falls back to executables from PATH.
# FFMPEG_BIN=C:\ffmpeg\bin\ffmpeg.exe
# FFPROBE_BIN=C:\ffmpeg\bin\ffprobe.exe

# yt-dlp
# Needed only for the Download screen / URL import workflow.
# If unset, runtime tries `yt\yt-dlp.exe` in the repo, then PATH.
# YT_DLP_BIN=C:\tools\yt-dlp.exe

# Azure Speech primary profile
# Used only when TTS provider is `azure_tts`.
# You can also store these in App Settings instead of env.
# AZURE_SPEECH_KEY=your_key_here
# AZURE_SPEECH_REGION=southeastasia

# Azure Speech secondary fallback profile
# Either *_SECONDARY or *_2 aliases are accepted.
# AZURE_SPEECH_KEY_SECONDARY=your_secondary_key_here
# AZURE_SPEECH_REGION_SECONDARY=southeastasia
# AZURE_SPEECH_KEY_2=your_secondary_key_here
# AZURE_SPEECH_REGION_2=southeastasia

# OCR note
# OCR mode does not use env vars. Install one of:
#   pip install paddleocr paddlepaddle
#   pip install rapidocr_onnxruntime
